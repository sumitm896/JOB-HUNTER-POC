# ============================================================================
#  JOB HUNTER — SECRETS / SETTINGS FILE
# ----------------------------------------------------------------------------
#  HOW TO USE:
#    1. Copy this file and rename the copy to ".env"  (just the dot + env)
#    2. Fill in the values on the right side of each "="
#    3. Run the script. It reads this file automatically.
#  You never need to open or edit job_hunter.py.
#
#  Rules:
#    - No spaces around the "=" sign.   KEY=value     (not  KEY = value)
#    - No quotes needed.
#    - Lists are comma-separated on a single line.
#    - Lines starting with "#" are comments and are ignored.
# ============================================================================


# ── REQUIRED: credentials ───────────────────────────────────────────────────
# Your Anthropic API key (starts with sk-ant-...). Get one at console.anthropic.com
ANTHROPIC_API_KEY=

# The Gmail account that SENDS the digest email.
GMAIL_ADDRESS=

# A Gmail "App Password" (NOT your normal password). Create one at:
# myaccount.google.com > Security > 2-Step Verification > App passwords
GMAIL_APP_PASSWORD=

# Where the digest is sent. Leave blank to send it to yourself (GMAIL_ADDRESS).
RECIPIENT_EMAIL=

# The ID of the Google Sheet used for de-duplication and run logs. It's the
# long string in the sheet's URL between "/d/" and "/edit":
#   docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
# Leave blank to run without Sheets logging (de-dup will be disabled).
GOOGLE_SHEET_ID=

# Path to your Google service-account JSON key file (for Sheets access).
# Create one in Google Cloud Console and share the sheet with its email.
# Leave blank if you're not using Sheets.
GOOGLE_CREDENTIALS_FILE=credentials.json


# ── REQUIRED: who you are and what you want ─────────────────────────────────
# Your name (appears in the email footer).
USER_NAME=Your Name

# Where you want to work. Text in (brackets) is just a note.
SEARCH_LOCATION=Ireland (incl. remote)

# The city/area you're based in.
BASED_IN=Dublin, Ireland

# The job titles you're hunting for — comma separated. Search queries are
# built from these automatically.
TARGET_ROLES=Technical Account Manager, Solutions Engineer, Customer Success Manager

# Plain-English description of what you want. This is fed straight to the AI,
# so write it however you like — what to find, what to avoid, seniority, etc.
SEARCH_FOCUS=Post-sales technical-relationship roles in SaaS/fintech across Ireland, including remote. A different product stack is fine. Avoid pure sales-quota roles.


# ── OPTIONAL: background (improves match scoring) ───────────────────────────
# How many years of relevant experience you have.
EXPERIENCE_YEARS=4

# Your highest / most relevant qualification.
EDUCATION=MSc Business Analytics, University of Galway

# Your transferable strengths — comma separated.
CORE_STRENGTHS=Post-sales technical relationship management, Escalation ownership, API/webhook troubleshooting, Driving adoption and retention

# Tools/tech you know — comma separated. Used only as a bonus signal, never a filter.
BONUS_STACK=REST APIs, Webhooks, SQL, Python, Postman

# Quantified achievements — comma separated.
IMPACT_HIGHLIGHTS=98% SLA compliance, 15-20% utilisation lift, 25% faster escalation resolution


# ── OPTIONAL: tuning knobs (safe to leave as-is) ────────────────────────────
# Hide any job that scores below this number (0-100). Set to 0 to show all.
MIN_MATCH_SCORE=65

# How many jobs to request per search.
JOBS_PER_QUERY=5

# Which Claude model to use.
MODEL_ID=claude-haiku-4-5
